# OpenClaw Runner — WSL (llama.cpp GGUF) example.
# Copy to runner.env and set values. Do not commit.
#
# This configuration uses llama.cpp with a GGUF model instead of vLLM.
# Benefits:
#   - Native GGUF support (no conversion needed)
#   - Lower VRAM requirements
#   - CPU inference support
#   - Better quantization options (Q4_K_M, Q8_0, etc.)
#
# Prerequisites:
#   1. Run: ./deploy/scripts/setup_llama_cpp.sh or ./deploy/install_wsl_llamacpp.sh
#   2. Ensure llama.cpp server is running: ~/.local/llama-cpp-server/start-server.sh
#      (or /opt/llama-cpp-server/start-server.sh for system installs)

# Broker (no trailing slash). Use Tailscale or host IP if broker is on VPS.
BROKER_URL=http://127.0.0.1:8000
WORKER_TOKEN=your_worker_token_here

# Worker identity and capabilities (broker routes llm_task jobs by caps).
# Using 'llm:llamacpp' distinguishes this worker from vLLM workers.
WORKER_ID=openclaw-wsl-llamacpp
WORKER_CAPS=llm:llamacpp,repo_tools
RUNNER_LOG_DIR=~/.local/state/openclaw-runner

# LLM (OpenAI-compatible llama.cpp server on WSL)
# The llama.cpp server provides an OpenAI-compatible API endpoint.
LLM_PROVIDER=openai_compat
LLM_BASE_URL=http://127.0.0.1:8000/v1  # Default llama.cpp server port
LLM_API_KEY=                          # Usually empty for local servers
LLM_MODEL=qwen2.5-coder-7b-instruct-q4_k_m.gguf  # Must match model filename
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096
LLM_TOOL_LOOP_MAX_STEPS=6
# LLM_ALLOWED_TOOLS=repo_list,repo_status,repo_last_commit,repo_grep,repo_readfile,plan_echo,approve_echo

# Repo (optional)
# RUNNER_REPOS_BASE=/home/user/src
# RUNNER_REPO_ALLOWLIST=/etc/openclaw/repos.json

# Poll and timeouts
# POLL_INTERVAL_SEC=10
# RESULT_TIMEOUT_SEC=300

# ============================================
# llama.cpp Server Configuration (reference)
# ============================================
# The llama.cpp server should be started separately. See:
#   ~/.local/llama-cpp-server/start-server.sh
#   or /opt/llama-cpp-server/start-server.sh for system installs
#
# Environment variables for the server (in ~/.local/llama-cpp-server/server.env for --user):
#   LLAMA_MODEL=qwen2.5-coder-7b-instruct-q4_k_m.gguf
#   LLAMA_PORT=8000
#   LLAMA_N_GPU_LAYERS=35    # Set to 0 for CPU-only
#   LLAMA_N_CTX=8192
#   MODELS_DIR=~/.local/share/openclaw-models
#
# To test the server:
#   ~/.local/llama-cpp-server/test-server.sh
#
# To check GPU layer recommendations for your model/VRAM:
#   - 7B model: 35 layers for full GPU offload on 8GB VRAM
#   - 7B model: 25 layers on 6GB VRAM
#   - 13B model: 41 layers on 12GB VRAM
#   - Adjust based on your GPU memory
