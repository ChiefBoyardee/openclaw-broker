# AI Website Generator Configuration
# Copy to website.env and customize for your instance. Do not commit website.env.
#
# This file configures the AI personality website generation system.
# For instance-specific theming and content, see custom_website_config.json

# -----------------------------------------------------------------------------
# Basic Website Settings
# -----------------------------------------------------------------------------

# Website base directory on the VPS (absolute path required)
VPS_WEBSITE_BASE=/var/www/ai-site

# Domain name for the website (must point to this VPS)
VPS_DOMAIN=ai.example.com

# Name of the AI persona (used for site identification)
VPS_PERSONA_NAME=assistant

# Path to persona configuration file (optional, for auto-importing personality)
VPS_PERSONALITY_FILE=/opt/config/persona.json

# -----------------------------------------------------------------------------
# Site Metadata
# -----------------------------------------------------------------------------

# Site name/title
VPS_SITE_NAME="AI Digital Garden"

# Tagline shown on homepage
VPS_TAGLINE="A collection of thoughts, learnings, and discoveries."

# Meta description for SEO
VPS_DESCRIPTION="An AI personality website with autonomous content generation."

# -----------------------------------------------------------------------------
# Nginx Configuration
# -----------------------------------------------------------------------------

# Enable nginx site management (true/false)
VPS_NGINX_ENABLED=true

# Enable SSL/HTTPS (requires certificates to be present)
VPS_NGINX_SSL=true

# Path to SSL certificates (Let's Encrypt default)
VPS_NGINX_CERT_PATH=/etc/letsencrypt/live

# Rate limiting: requests per second
VPS_RATE_LIMIT_RPS=10

# Rate limiting: burst capacity
VPS_RATE_LIMIT_BURST=20

# -----------------------------------------------------------------------------
# Security & Limits
# -----------------------------------------------------------------------------

# Maximum file size for website content (bytes)
VPS_MAX_FILE_SIZE=500000

# Allowed file extensions for uploads (comma-separated)
VPS_ALLOWED_EXTENSIONS=.html,.css,.js,.png,.jpg,.jpeg,.gif,.svg,.md,.txt

# -----------------------------------------------------------------------------
# Content Generation
# -----------------------------------------------------------------------------

# Enable automatic content from self-memory system
VPS_SYNC_MEMORY=true

# Minimum memory importance to include (0.0 - 2.0)
VPS_MEMORY_IMPORTANCE_THRESHOLD=1.0

# Maximum items per section on homepage
VPS_MAX_HOMEpage_ITEMS=5

# -----------------------------------------------------------------------------
# Advanced Options
# -----------------------------------------------------------------------------

# Custom configuration file path (instance-specific settings)
VPS_CONFIG_FILE=custom_website_config.json

# Nginx server block template (default or custom path)
VPS_NGINX_TEMPLATE=default

# Enable HTTP/2 (requires SSL)
VPS_NGINX_HTTP2=true

# Additional nginx security headers (JSON format)
# VPS_NGINX_EXTRA_HEADERS='{"X-Custom-Header": "value"}'
