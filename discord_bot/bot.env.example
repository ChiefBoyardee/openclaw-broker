# OpenClaw Discord Bot — copy to bot.env and set values. Do not commit bot.env.
# Production: place at /opt/openclaw-discord-bot/bot.env (or path used by systemd).

# Discord bot token (from Discord Developer Portal)
DISCORD_TOKEN=your_discord_bot_token_here

# Broker base URL and same BOT_TOKEN as broker (X-Bot-Token)
BROKER_URL=http://127.0.0.1:8000
BOT_TOKEN=your_bot_token_here

# Instance name (optional; systemd sets INSTANCE_NAME=%i for templated units)
# INSTANCE_NAME=default

# whoami broker URL: full (default), masked (scheme+host only), hidden (show "(hidden)")
# WHOAMI_BROKER_URL_MODE=full

# Single Discord user ID allowed (right-click user -> Copy ID). Backward compatible.
ALLOWED_USER_ID=123456789012345678

# Optional: additional user IDs, comma- or space-separated (complements ALLOWED_USER_ID)
# ALLOWLIST_USER_ID=111,222 333

# Optional: single channel ID to allow (leave empty for DMs only)
# ALLOWED_CHANNEL_ID=

# Polling for job result
JOB_POLL_INTERVAL_SEC=2
JOB_POLL_TIMEOUT_SEC=120

# Guardrails (per user): cooldown between commands (seconds), max concurrent jobs (queued+running)
# BOT_COOLDOWN_SECONDS=3
# BOT_MAX_CONCURRENT=1

# Discord presence / status shown under the bot's name
# BOT_PRESENCE=Listening to DMs

# --- Conversation & Memory ---
# Enable conversational features (memory, personas, chat fallback)
# MEMORY_ENABLED=true

# Default personality to use (must be a key from built-in personas or custom_personas.json)
# DEFAULT_PERSONA=helpful_assistant
# Path to custom personas JSON file (relative to working directory / bot instance dir)
# Copy discord_bot/custom_personas.json.example to this path and customize.
# CUSTOM_PERSONAS_PATH=custom_personas.json

# Embedding provider for semantic memory search: 'openai', 'local', or 'none'
# EMBEDDING_PROVIDER=none
# OPENAI_API_KEY=sk-...
# Default OpenAI model or huggingface local model (e.g. Qwen/Qwen3-Embedding-0.6B)
# EMBEDDING_MODEL=text-embedding-3-small
