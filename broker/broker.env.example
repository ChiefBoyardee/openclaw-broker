# OpenClaw Broker — copy to broker.env and set values. Do not commit broker.env.
# Production: place at /opt/openclaw-broker/broker.env (or path used by systemd).

# Database path (default for production)
BROKER_DB=/var/lib/openclaw-broker/broker.db

# Required: tokens for API auth (generate with: openssl rand -hex 32)
WORKER_TOKEN=your_worker_token_here
BOT_TOKEN=your_bot_token_here

# Optional: max queued + running jobs; reject new creates with 429 when at cap (unset = no limit)
# MAX_QUEUED_JOBS=100

# Optional: rate limit jobs per minute per BOT_TOKEN (unset = no limit)
# RATE_LIMIT_JOBS_PER_MIN=60

# Optional: max request body size in bytes (default 524288 = 512KB); 413 if exceeded
# MAX_REQUEST_BODY_BYTES=524288

# Server bind: prefer 127.0.0.1 or Tailscale IP. 0.0.0.0 = all interfaces (see docs)
BROKER_HOST=127.0.0.1
BROKER_PORT=8000

# If binding to 0.0.0.0, set BROKER_BIND_PUBLIC=1 to suppress startup warning
# BROKER_BIND_PUBLIC=1
